<?xml version='1.0' encoding='utf-8'?>
<mujoco model="robotiq_2f85">
  <include file="adapter_assets.xml"/>

  <option cone="elliptic" impratio="10"/>

  <default>
    <default class="2f85">
      <mesh scale="0.001 0.001 0.001"/>
      <general biastype="affine"/>
      <joint axis="1 0 0"/>
      <default class="driver">
        <joint range="0 0.8" armature="0.005" damping="0.1" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
      </default>
      <default class="follower">
        <joint range="-0.872664 0.872664" armature="0.001" pos="0 -0.018 0.0065" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
      </default>
      <default class="spring_link">
        <joint range="-0.29670597283 0.8" armature="0.001" stiffness="0.05" springref="2.62" damping="0.00125"/>
      </default>
      <default class="coupler">
        <joint range="-1.57 0" armature="0.001" solimplimit="0.95 0.99 0.001" solreflimit="0.005 1"/>
      </default>
      <default class="robotiq_visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="robotiq_collision">
        <geom type="mesh" group="3"/>
        <default class="pad_box1">
          <geom mass="0" type="box" pos="0 -0.0026 0.028125" size="0.011 0.004 0.009375"
            friction="0.7" solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.55 0.55 0.55 1"/>
        </default>
        <default class="pad_box2">
          <geom mass="0" type="box" pos="0 -0.0026 0.009375" size="0.011 0.004 0.009375"
            friction="0.6" solimp="0.95 0.99 0.001" solref="0.004 1" priority="1" rgba="0.45 0.45 0.45 1"/>
        </default>
      </default>
    </default>
  </default>

  <asset>

    <!-- Franka hand palm meshes (absolute paths, no meshdir dependency) -->
    <material name="franka_white"     rgba="1 1 1 1"/>
    <material name="franka_off_white" rgba="0.901961 0.921569 0.929412 1"/>
    <material name="franka_black"     rgba="0.25 0.25 0.25 1"/>
    <mesh name="franka_hand_c"  file="/home/mourya/one_hand_ws/src/mujoco_menagerie/franka_emika_panda/assets/hand.stl"/>
    <mesh name="franka_hand_0"  file="/home/mourya/one_hand_ws/src/mujoco_menagerie/franka_emika_panda/assets/hand_0.obj"/>
    <mesh name="franka_hand_1"  file="/home/mourya/one_hand_ws/src/mujoco_menagerie/franka_emika_panda/assets/hand_1.obj"/>
    <mesh name="franka_hand_2"  file="/home/mourya/one_hand_ws/src/mujoco_menagerie/franka_emika_panda/assets/hand_2.obj"/>
    <mesh name="franka_hand_3"  file="/home/mourya/one_hand_ws/src/mujoco_menagerie/franka_emika_panda/assets/hand_3.obj"/>
    <mesh name="franka_hand_4"  file="/home/mourya/one_hand_ws/src/mujoco_menagerie/franka_emika_panda/assets/hand_4.obj"/>
    <material name="robotiq_metal"    rgba="0.58   0.58   0.58   1"/>
    <material name="robotiq_silicone" rgba="0.1882 0.1882 0.1882 1"/>
    <material name="robotiq_gray"     rgba="0.4627 0.4627 0.4627 1"/>
    <material name="robotiq_black"    rgba="0.149  0.149  0.149  1"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/base_mount.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/base.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/driver.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/coupler.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/follower.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/pad.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/silicone_pad.stl"/>
    <mesh class="2f85" file="/home/mourya/one_hand_ws/src/mujoco_menagerie/robotiq_2f85/assets/spring_link.stl"/>
    </asset>

  <worldbody>
    <body name="tool_physical_robotiq_2f85" pos="-0.59 -0.8 0.533" quat="0.9238795 0 0 0.3826834" childclass="2f85">
      <freejoint/>
      <inertial mass="2.0" pos="0 0 -0.1" diaginertia="0.01 0.01 0.005"/>

      <!-- 1. Custom Male Adapter (Flipped 180deg so flat base is at Z=-0.019, pegs pointing UP at Z=0 towards bare robot wrist) -->
      <body name="custom_adapter" pos="0 0 0" quat="0 1 0 0">
        <geom type="mesh" mesh="franka_adapter_male" material="robotiq_black" contype="0" conaffinity="0" group="2"/>
        <geom type="cylinder" size="0.038 0.001" pos="0 0 0.019" material="robotiq_black" contype="0" conaffinity="0" group="2"/>
        <geom type="box" size="0.03 0.001 0.01" pos="0 -0.0415 0.01" material="robotiq_black" contype="0" conaffinity="0" group="2"/>
        <geom type="box" size="0.03 0.001 0.01" pos="0 0.0415 0.01" material="robotiq_black" contype="0" conaffinity="0" group="2"/>
      </body>

      <!-- 2. Flat Plane Spacer (Covers the native Robotiq base_mount pins and provides a flush surface) -->
      <!-- Radius 40mm, Height 10mm (half-size 0.005). Placed immediately below adapter's flat face at Z=-0.019 -->
      <!-- Center = -0.019 - 0.005 = -0.024 -->
      <geom type="cylinder" size="0.04 0.005" pos="0 0 -0.024" material="robotiq_gray" contype="1" conaffinity="1"/>

      <!-- 3. Native Robotiq Tool Connector -->
      <!-- Flipped 180deg around Y (quat 0 1 0 0) so its flat top faces UP into the spacer block's bottom (Z=-0.029) -->
      <body name="robotiq_tool_connector" pos="0 0 -0.029" quat="0 1 0 0">
        <geom class="robotiq_visual"    mesh="base_mount" material="robotiq_black"/>
        <geom class="robotiq_collision" mesh="base_mount"/>

            <!-- Full Robotiq 2F-85 gripper below base_mount -->
            <body name="base" pos="0 0 0.0038" quat="1 0 0 -1">
              <inertial mass="0.777441" pos="0 -2.70394e-05 0.0354675" quat="1 -0.00152849 0 0"
                diaginertia="0.000260285 0.000225381 0.000152708"/>
              <geom class="robotiq_visual"    mesh="base" material="robotiq_black"/>
              <geom class="robotiq_collision" mesh="base"/>
              <site name="pinch" pos="0 0 0.145" type="sphere" group="5" rgba="0.9 0.9 0.9 1" size="0.005"/>

              <body name="right_driver" pos="0 0.0306011 0.054904">
                <inertial mass="0.00899563" pos="2.96931e-12 0.0177547 0.00107314" quat="0.681301 0.732003 0 0"
                  diaginertia="1.72352e-06 1.60906e-06 3.22006e-07"/>
                <joint name="right_driver_joint" class="driver"/>
                <geom class="robotiq_visual"    mesh="driver" material="robotiq_gray"/>
                <geom class="robotiq_collision" mesh="driver"/>
                <body name="right_coupler" pos="0 0.0315 -0.0041">
                  <inertial mass="0.0140974" pos="0 0.00301209 0.0232175" quat="0.705636 -0.0455904 0.0455904 0.705636"
                    diaginertia="4.16206e-06 3.52216e-06 8.88131e-07"/>
                  <joint name="right_coupler_joint" class="coupler"/>
                  <geom class="robotiq_visual"    mesh="coupler" material="robotiq_black"/>
                  <geom class="robotiq_collision" mesh="coupler"/>
                </body>
              </body>
              <body name="right_spring_link" pos="0 0.0132 0.0609">
                <inertial mass="0.0221642" pos="-8.65005e-09 0.0181624 0.0212658" quat="0.663403 -0.244737 0.244737 0.663403"
                  diaginertia="8.96853e-06 6.71733e-06 2.63931e-06"/>
                <joint name="right_spring_link_joint" class="spring_link"/>
                <geom class="robotiq_visual"    mesh="spring_link" material="robotiq_black"/>
                <geom class="robotiq_collision" mesh="spring_link"/>
                <body name="right_follower" pos="0 0.055 0.0375">
                  <inertial mass="0.0125222" pos="0 -0.011046 0.0124786" quat="1 0.1664 0 0"
                    diaginertia="2.67415e-06 2.4559e-06 6.02031e-07"/>
                  <joint name="right_follower_joint" class="follower"/>
                  <geom class="robotiq_visual"    mesh="follower" material="robotiq_black"/>
                  <geom class="robotiq_collision" mesh="follower"/>
                  <body name="right_pad" pos="0 -0.0189 0.01352">
                    <geom class="pad_box1" name="right_pad1"/>
                    <geom class="pad_box2" name="right_pad2"/>
                    <inertial mass="0.0035" pos="0 -0.0025 0.0185" quat="0.707107 0 0 0.707107"
                      diaginertia="4.73958e-07 3.64583e-07 1.23958e-07"/>
                    <geom class="robotiq_visual" mesh="pad"/>
                    <body name="right_silicone_pad">
                      <geom class="robotiq_visual" mesh="silicone_pad" material="robotiq_black"/>
                    </body>
                  </body>
                </body>
              </body>
              <body name="left_driver" pos="0 -0.0306011 0.054904" quat="0 0 0 1">
                <inertial mass="0.00899563" pos="0 0.0177547 0.00107314" quat="0.681301 0.732003 0 0"
                  diaginertia="1.72352e-06 1.60906e-06 3.22006e-07"/>
                <joint name="left_driver_joint" class="driver"/>
                <geom class="robotiq_visual"    mesh="driver" material="robotiq_gray"/>
                <geom class="robotiq_collision" mesh="driver"/>
                <body name="left_coupler" pos="0 0.0315 -0.0041">
                  <inertial mass="0.0140974" pos="0 0.00301209 0.0232175" quat="0.705636 -0.0455904 0.0455904 0.705636"
                    diaginertia="4.16206e-06 3.52216e-06 8.88131e-07"/>
                  <joint name="left_coupler_joint" class="coupler"/>
                  <geom class="robotiq_visual"    mesh="coupler" material="robotiq_black"/>
                  <geom class="robotiq_collision" mesh="coupler"/>
                </body>
              </body>
              <body name="left_spring_link" pos="0 -0.0132 0.0609" quat="0 0 0 1">
                <inertial mass="0.0221642" pos="-8.65005e-09 0.0181624 0.0212658" quat="0.663403 -0.244737 0.244737 0.663403"
                  diaginertia="8.96853e-06 6.71733e-06 2.63931e-06"/>
                <joint name="left_spring_link_joint" class="spring_link"/>
                <geom class="robotiq_visual"    mesh="spring_link" material="robotiq_black"/>
                <geom class="robotiq_collision" mesh="spring_link"/>
                <body name="left_follower" pos="0 0.055 0.0375">
                  <inertial mass="0.0125222" pos="0 -0.011046 0.0124786" quat="1 0.1664 0 0"
                    diaginertia="2.67415e-06 2.4559e-06 6.02031e-07"/>
                  <joint name="left_follower_joint" class="follower"/>
                  <geom class="robotiq_visual"    mesh="follower" material="robotiq_black"/>
                  <geom class="robotiq_collision" mesh="follower"/>
                  <body name="left_pad" pos="0 -0.0189 0.01352">
                    <geom class="pad_box1" name="left_pad1"/>
                    <geom class="pad_box2" name="left_pad2"/>
                    <inertial mass="0.0035" pos="0 -0.0025 0.0185" quat="1 0 0 1"
                      diaginertia="4.73958e-07 3.64583e-07 1.23958e-07"/>
                    <geom class="robotiq_visual" mesh="pad"/>
                    <body name="left_silicone_pad">
                      <geom class="robotiq_visual" mesh="silicone_pad" material="robotiq_black"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
        </body>
      </body>
  </worldbody>

  <contact>
    <exclude body1="base" body2="left_driver"/>
    <exclude body1="base" body2="right_driver"/>
    <exclude body1="base" body2="left_spring_link"/>
    <exclude body1="base" body2="right_spring_link"/>
    <exclude body1="right_coupler" body2="right_follower"/>
    <exclude body1="left_coupler"  body2="left_follower"/>
  </contact>

  <tendon>
    <fixed name="split">
      <joint joint="right_driver_joint" coef="0.5"/>
      <joint joint="left_driver_joint"  coef="0.5"/>
    </fixed>
  </tendon>

  <equality>
    <connect anchor="0 0 0" body1="right_follower" body2="right_coupler" solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <connect anchor="0 0 0" body1="left_follower"  body2="left_coupler"  solimp="0.95 0.99 0.001" solref="0.005 1"/>
    <joint joint1="right_driver_joint" joint2="left_driver_joint" polycoef="0 1 0 0 0" solimp="0.95 0.99 0.001" solref="0.005 1"/>
  </equality>

  <actuator>
    <general class="2f85" name="fingers_actuator" tendon="split" forcerange="-5 5" ctrlrange="0 255"
      gainprm="0.3137255 0 0" biasprm="0 -100 -10"/>
  </actuator>
</mujoco>
