<mujoco model="kitchen_scene">
    <include file="panda.xml"/>

    <statistic center="0 0 0.5" extent="2"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>

    <include file="k/kitchen.xml"/>

    <asset>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <geom name="floor" pos="0 0 -0.85" size="0 0 0.05" type="plane" material="groundplane" contype="1" conaffinity="1"/>
        <geom name="pedestal" pos="-0.25 0 -0.225" size="0.1 0.1 0.625" type="box" rgba="0.2 0.2 0.2 1" contype="1" conaffinity="1"/>
        
        <!-- Verification Heavy Box (falls onto the arm to test collisions) -->
        <body name="heavy_collision_test" pos="-0.25 0.0 1.5">
            <freejoint/>
            <inertial mass="10.0" pos="0 0 0" diaginertia="0.1 0.1 0.1"/>
            <geom type="box" size="0.15 0.15 0.15" rgba="0.9 0.1 0.1 1" contype="1" conaffinity="1"/>
        </body>
    </worldbody>
    <!-- High fidelity scanned objects -->
    <include file="o/brisk_tea/prefixed.xml"/>
    <include file="o/frypan/prefixed.xml"/>
    <include file="o/donut/prefixed.xml"/>
    <include file="o/coffee/prefixed.xml"/>
    <include file="o/mug/prefixed.xml"/>
    <include file="o/robosuite_objects/cereal.xml"/>
    <include file="o/robosuite_objects/milk.xml"/>
    <include file="o/robosuite_objects/bread.xml"/>

</mujoco>
